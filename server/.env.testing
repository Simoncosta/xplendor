APP_NAME=Xplendor
APP_ENV=testing
APP_KEY=base64:suBcKqNAZkMUxbjQIlmhz+L17rn6o10E4wnyxRGEvmo=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt
APP_FALLBACK_LOCALE=pt
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==============================================================================
# Isolamento de testes — SQLite em memória.
#
# NUNCA mudar isto para mysql/MariaDB. Se mudar, os testes (RefreshDatabase
# trait) vão fazer migrate:fresh contra a BD real e apagam tudo. Incidente
# documentado no CLAUDE.md sec 14.3 (2026-06-09).
#
# Defesas em camadas:
#   1. Este ficheiro (.env.testing) — DB sqlite isolada.
#   2. phpunit.xml — <env> com force="true" para sobrescrever qualquer outro.
#   3. AppServiceProvider — prohibitDestructiveCommands fora de testing.
# ==============================================================================
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

SESSION_DRIVER=array
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=array

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
